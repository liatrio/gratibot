{
  "name": "gratibot",
  "version": "0.0.0-development",
  "description": "Slack bot for peer recognition at Liatrio",
  "main": "app.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "prepare": "husky",
    "start": "node app.js",
    "test": "c8 mocha test/* --recursive --require test/setup.js",
    "lint": "eslint '*.js' 'features/**' 'service/**' 'database/**' 'middleware/**' 'test/**'",
    "lint:fix": "eslint '*.js' 'features/**' 'service/**' 'database/**' 'middleware/**' 'test/**' --fix",
    "release": "semantic-release"
  },
  "dependencies": {
    "@slack/bolt": "^4.1.1",
    "express": "^5.0.0",
    "lodash": "^4.18.1",
    "moment-timezone": "^0.6.0",
    "mongodb": "^6.21.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.14.0",
    "c8": "^10.1.3",
    "chai": "^6.0.0",
    "chai-as-promised": "^8.0.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-mocha": "^10.5.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "mocha": "^11.0.1",
    "mocha-suppress-logs": "^0.6.0",
    "prettier": "^3.4.2",
    "semantic-release": "^25.0.0",
    "sinon": "^21.0.0"
  },
  "overrides": {
    "conventional-changelog-conventionalcommits": ">= 8.0.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "c8": {
    "reporter": [
      "text",
      "lcov"
    ],
    "all": true,
    "include": [
      "service/**",
      "features/**",
      "database/**",
      "middleware/**"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/liatrio/gratibot.git"
  }
}
